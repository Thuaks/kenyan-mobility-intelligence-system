# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Kenya Urban Mobility Intelligence Platform"
APP_ENV=development           # development | staging | production
APP_VERSION=1.0.0
DEBUG=true

# ── API Server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./kumip.db        # dev: sqlite | prod: postgresql://...
DUCKDB_PATH=./data/kumip_analytics.duckdb

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# ── External APIs (optional — leave blank to use synthetic data) ───────────────
TWITTER_BEARER_TOKEN=
NASA_POWER_API_BASE=https://power.larc.nasa.gov/api/temporal/daily/point
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox

# ── ML ────────────────────────────────────────────────────────────────────────
MODELS_DIR=./models/saved
RETRAIN_SCHEDULE_HOUR=2        # 2am EAT daily retraining cron

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/kumip.log
